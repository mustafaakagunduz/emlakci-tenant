DATABASE_URL="postgresql://emlak:emlak@localhost:5433/emlakpanel?schema=public"
PORT=3000
JWT_SECRET="change-me-in-local-env"
CORS_ORIGIN="http://localhost:5173"

# Faz 5 — fotoğraf yükleme (Cloudinary). Boş bırakılırsa uygulama yine ayağa
# kalkar, yalnızca /properties/:id/photos/* endpoint'leri 503 döner.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Faz 6 — konum seçiminde reverse geocoding (Nominatim/OpenStreetMap).
# Nominatim politikası tanımlayıcı bir User-Agent ister (uygulama adı + iletişim e-postası).
NOMINATIM_USER_AGENT="EmlakPanel/1.0 (you@example.com)"
